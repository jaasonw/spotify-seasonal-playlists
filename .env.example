# Spotify API Credentials
client_id=your_spotify_client_id
client_secret=your_spotify_client_secret
redirect_uri=http://your-domain:8090
port=8080

# Flask Secret Key (generate a random string)
FLASK_SECRET_KEY=your-random-secret-key-here

# URL Configuration (for reverse proxy setups like /spotify)
# Leave empty for root path (e.g., http://localhost:8090/)
# Use /spotify for subdirectory (e.g., http://localhost/spotify/)
URL_PREFIX=/spotify

# PocketBase Configuration
pocketbase_url=http://spotify-seasonal-database:8090
pocketbase_username=your_pocketbase_admin_email
pocketbase_password=your_pocketbase_admin_password
